<?xml version="1.0" encoding="utf-8"?>
<!--
  packages.config — Registre des packages NuGet du projet Karaté
  ================================================================
  Ce fichier liste tous les packages NuGet installés dans le projet,
  avec leur version exacte et le framework .NET cible (net472 = .NET 4.7.2).
  Il est utilisé par NuGet pour restaurer les dépendances (nuget restore).

  PACKAGES INSTALLÉS :
  ┌─────────────────────────────────────────────────┬──────────┬─────────────────────────────────────────────────────────┐
  │ Package                                         │ Version  │ Rôle                                                    │
  ├─────────────────────────────────────────────────┼──────────┼─────────────────────────────────────────────────────────┤
  │ MySql.Data                                      │ 9.2.0    │ Connecteur officiel MySQL pour .NET (Oracle)            │
  │ BouncyCastle.Cryptography                       │ 2.3.1    │ Cryptographie (SSL/TLS pour MySql.Data)                 │
  │ Google.Protobuf                                 │ 3.26.1   │ Sérialisation Protocol Buffers (requis par MySql.Data)  │
  │ K4os.Compression.LZ4                            │ 1.3.8    │ Compression LZ4 (dépendance de MySql.Data)             │
  │ K4os.Compression.LZ4.Streams                   │ 1.3.8    │ Flux compressés LZ4 (dépendance de MySql.Data)         │
  │ K4os.Hash.xxHash                                │ 1.0.8    │ Hash rapide xxHash (dépendance transitive)             │
  │ Microsoft.Bcl.AsyncInterfaces                   │ 5.0.0    │ Interfaces async pour .NET Framework 4.x               │
  │ System.Buffers                                  │ 4.5.1    │ Gestion de buffers mémoire performante                 │
  │ System.Configuration.ConfigurationManager       │ 8.0.0    │ Accès à la configuration app (App.config)              │
  │ System.Diagnostics.DiagnosticSource             │ 8.0.1    │ Instrumentation/diagnostics (dépendance transitive)    │
  │ System.IO.Pipelines                             │ 5.0.2    │ I/O pipelines hautes performances                      │
  │ System.Memory                                   │ 4.5.5    │ Span<T>, Memory<T> pour .NET Framework                 │
  │ System.Numerics.Vectors                         │ 4.5.0    │ Vecteurs SIMD (dépendance transitive)                  │
  │ System.Runtime.CompilerServices.Unsafe          │ 6.0.0    │ Accès mémoire non sécurisé (dépendance transitive)     │
  │ System.Threading.Tasks.Extensions              │ 4.5.4    │ Extensions async/await pour .NET Framework             │
  │ ZstdSharp.Port                                  │ 0.8.0    │ Compression Zstandard (dépendance de MySql.Data)       │
  └─────────────────────────────────────────────────┴──────────┴─────────────────────────────────────────────────────────┘
-->
<packages>
  <!-- Connecteur MySQL principal — dépendance directe du projet -->
  <package id="BouncyCastle.Cryptography" version="2.3.1" targetFramework="net472" />
  <package id="Google.Protobuf" version="3.26.1" targetFramework="net472" />
  <package id="K4os.Compression.LZ4" version="1.3.8" targetFramework="net472" />
  <package id="K4os.Compression.LZ4.Streams" version="1.3.8" targetFramework="net472" />
  <package id="K4os.Hash.xxHash" version="1.0.8" targetFramework="net472" />
  <package id="Microsoft.Bcl.AsyncInterfaces" version="5.0.0" targetFramework="net472" />
  <package id="MySql.Data" version="9.2.0" targetFramework="net472" />
  <package id="System.Buffers" version="4.5.1" targetFramework="net472" />
  <package id="System.Configuration.ConfigurationManager" version="8.0.0" targetFramework="net472" />
  <package id="System.Diagnostics.DiagnosticSource" version="8.0.1" targetFramework="net472" />
  <package id="System.IO.Pipelines" version="5.0.2" targetFramework="net472" />
  <package id="System.Memory" version="4.5.5" targetFramework="net472" />
  <package id="System.Numerics.Vectors" version="4.5.0" targetFramework="net472" />
  <package id="System.Runtime.CompilerServices.Unsafe" version="6.0.0" targetFramework="net472" />
  <package id="System.Threading.Tasks.Extensions" version="4.5.4" targetFramework="net472" />
  <package id="ZstdSharp.Port" version="0.8.0" targetFramework="net472" />
</packages>
