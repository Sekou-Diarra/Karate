<?xml version="1.0" encoding="utf-8"?>
<!--
  App.config — Fichier de configuration de l'application Karaté
  ================================================================
  Ce fichier est lu par le CLR .NET au démarrage de l'application.
  Il définit :
    1. Le runtime cible (.NET Framework 4.7.2)
    2. Les redirections de binding d'assembly (assembly binding redirects)
       pour résoudre les conflits de versions entre les packages NuGet.

  Les redirections ci-dessous ont été générées automatiquement par Visual Studio
  lors de l'ajout des packages NuGet MySql.Data et ses dépendances.
-->
<configuration>

  <!-- Section startup : spécifie le runtime .NET supporté par l'application -->
  <startup>
    <!--
      supportedRuntime : indique que l'application cible .NET Framework 4.7.2.
      - version="v4.0" : version CLR (Common Language Runtime) utilisée
      - sku=".NETFramework,Version=v4.7.2" : version exacte du framework
    -->
    <supportedRuntime version="v4.0" sku=".NETFramework,Version=v4.7.2" />
  </startup>

  <!-- Section runtime : configuration avancée du CLR -->
  <runtime>
    <assemblyBinding xmlns="urn:schemas-microsoft-com:asm.v1">

      <!--
        Redirection de binding pour System.Runtime.CompilerServices.Unsafe.
        Raison : plusieurs packages NuGet (MySql.Data, System.Memory, etc.)
        référencent différentes versions de cette bibliothèque. Cette redirection
        force l'utilisation de la version 6.0.0.0 pour tous.
      -->
      <dependentAssembly>
        <assemblyIdentity name="System.Runtime.CompilerServices.Unsafe"
                          publicKeyToken="b03f5f7f11d50a3a"
                          culture="neutral" />
        <!-- Toute version de 0.0.0.0 à 6.0.0.0 est redirigée vers 6.0.0.0 -->
        <bindingRedirect oldVersion="0.0.0.0-6.0.0.0" newVersion="6.0.0.0" />
      </dependentAssembly>

      <!--
        Redirection de binding pour System.Memory.
        Raison : différentes versions référencées par les dépendances transitives.
        Toutes les versions sont redirigées vers 4.0.1.2.
      -->
      <dependentAssembly>
        <assemblyIdentity name="System.Memory"
                          publicKeyToken="cc7b13ffcd2ddd51"
                          culture="neutral" />
        <!-- Toute version de 0.0.0.0 à 4.0.1.2 est redirigée vers 4.0.1.2 -->
        <bindingRedirect oldVersion="0.0.0.0-4.0.1.2" newVersion="4.0.1.2" />
      </dependentAssembly>

    </assemblyBinding>
  </runtime>

</configuration>
